# ============================================
# Bitget API Credentials
# ============================================
# Get your API keys from: https://www.bitget.com/account/newapi
# Make sure to enable "Futures Trading" permission
#
BITGET_API_KEY=your_api_key_here
BITGET_SECRET_KEY=your_secret_key_here
BITGET_PASSPHRASE=your_passphrase_here

# ============================================
# Bot Configuration (Optional Overrides)
# ============================================
# Initial capital (default: 40)
INITIAL_CAPITAL=40

# Max drawdown percentage (default: 15)
MAX_DRAWDOWN_PCT=15

# Max daily loss percentage (default: 5)
MAX_DAILY_LOSS_PCT=5

# Enable paper trading mode (default: true)
# Set to false for live trading with real money
PAPER_TRADING=true

# Dashboard port (default: 8888)
DASHBOARD_PORT=8888

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# Telegram Notifications (Optional)
# ============================================
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
